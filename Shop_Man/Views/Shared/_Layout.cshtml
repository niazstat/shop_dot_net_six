<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>

    <link href="~/assets2/styles/main.07a59de7b920cd76b874.css" rel="stylesheet" />
    <script src="~/assets2/scripts/main.07a59de7b920cd76b874.js"></script>
</head>
<body>
    <div class="bg-dark text-white p-2">
        <div class="container-fluid">
            <div class="row">
                <div class="col navbar-brand">Order Management</div>
                <div class="col-6 text-right">
                    @*<vc:cart-summary />*@
                </div>
            </div>
        </div>
    </div>
    <div class="row m-1 p-1">
        <div id="categories" class="col-3">
            @await Component.InvokeAsync("NavigationMenu")
            @*<vc:navigation-menu />*@
        </div>
        <div class="col-9">
            @RenderBody()
        </div>
    </div>
</body>
</html>
