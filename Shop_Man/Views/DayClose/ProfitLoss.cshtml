
@{
    ViewData["Title"] = "ProfitLoss";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


@section HeadingText {
    <div class="page-title-heading text-dark text-center">
        .:: Yearly Profit Loss ::.
    </div>

}




<div class="row flex-sm-row">
    <div class="col-md-12">

        <div class="main-card mb-3 card">
            <div class="card-body">

                <div class="form-group row" style="margin-bottom:5px;">
                    <label for="inputEmail3" class="col-sm-2 col-form-label">From:</label>
                    <div class="col-sm-3">
                        <input type="text" class="mb-1 form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDate">
                    </div>

                    <label for="inputEmail3" class="col-sm-2 col-form-label">To:</label>
                    <div class="col-sm-3">
                        <input type="text" class="mb-1 form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDate2">
                    </div>

                    <div class="col-sm-2">
                        <a href="#" target="_blank" class="btn btn-block btn-gradient-info reports" id="btnDatewiseProfit" data-type="profitLossDate">Datewise Report</a>
                    </div>


                </div>


  
                <span id="spInfo">

                </span>
            </div>

        </div>

    </div>


</div>





<div class="row flex-sm-row">




</div>

<div class="row flex-sm-row">

</div>

<div class="row flex-sm-row">
    <div class="col-md-12">

        <div class="main-card mb-3 card">
            <div class="card-body">

                <div class="form-group row" style="margin-bottom:5px;">
                    <label for="inputEmail3" class="col-sm-2 col-form-label">Year Name:</label>
                    <div class="col-sm-3">
                        <select id="dropYear" class="mb-1 form-control-sm form-control">
                        </select>
                    </div>

                    <div class="col-md-3">
                        <a href="#" target="_blank" class="btn btn-block btn-gradient-warning reports" id="btnYearlyProfit" data-type="profitLoss">Yearly Proft Loss</a>
                    </div>
                </div>

            </div>

        </div>

    </div>



</div>

<script type="text/javascript">

        var days = ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'];
        var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];


        var datePicker1;

        var datePicker2;

        $(document).ready(function () {

            var date = new Date();
            var today = date.getDate() + '-' + months[date.getMonth()] + '-' + date.getFullYear();


            datePicker1 = flatpickr("#txtDate", { dateFormat: "d-M-Y" });
            datePicker1.setDate(date);

            datePicker2 = flatpickr("#txtDate2", { dateFormat: "d-M-Y" });
            datePicker2.setDate(date);


            bindYear();

            function bindYear() {
                let _minYear = 2019;
                let _maxYear = date.getFullYear();


                for (var i = _minYear; i <= _maxYear; i++) {
                    const newOption = `<option value="${i}">${i}</option>`;
                    $('#dropYear').append(newOption); // Add new option to the dropdown
                }





            }



            $("a.reports").on('click', function () {
                $("#spInfo").html('');


                var _fromDate = $("#txtDate").val();
                var _toDate = $("#txtDate2").val();
                var type2 = $('input[name="options"]:checked').val();

                var type = $(this).attr('data-type');


                var _yearName = $('#dropYear').val();
                if (type == 'profitLoss') {
                    $(this).attr('href', WEB_URL + 'Dayclose/YearlyReport?fromDate=01-Jan-' + _yearName + "&&ToDate=01-Jan-" + _yearName + "&&Type=Year"  );

                }
                if (type == 'profitLossDate') {
                    $(this).attr('href', WEB_URL + 'Dayclose/YearlyReport?fromDate=' + _fromDate + "&&ToDate=" + _toDate  + "&&Type=Date");

                }
             

            });

        });

</script>


