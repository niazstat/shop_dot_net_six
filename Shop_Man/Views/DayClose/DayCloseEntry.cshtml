                        </div>

                    </div>
                    <br />
                    <br />

                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label"> মোট বিক্রয় :</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" id="txtTotalSell" />


                        </div>

                        <label for="inputEmail3" class="col-sm-2 col-form-label"> মোট বিক্রয়  জোড়া :</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" id="txtTotalSellQty" />


                        </div>




                    </div>



                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label"> মোট বিক্রয় রিটার্ন :</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" id="txtTotalSellReturn" />


                        </div>

                        <label for="inputEmail3" class="col-sm-2 col-form-label"> মোট বিক্রয় রিটার্ন  জোড়া :</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" id="txtTotalSellQtyReturn" />


                        </div>




                    </div>



                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label"> মোট ক্রয় :</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" id="txtTotalBuy" />


                        </div>
                        <label for="inputEmail3" class="col-sm-2 col-form-label"> মোট ক্রয় জোড়া :</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" id="txtTotalBuyQty" />


                        </div>

                        <div class="col-sm-2">
                            <input type="button" value="View Details" class="btn btn-gradient-info " id="btnBalDetailsSales" />


                        </div>


                    </div>




                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">নোট  :</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" id="txtNote" />


                        </div>


                    </div>



                    <div class="form-group row">
                        <div class="col-sm-12">
                            <span id="spInfo">

                            </span>
                        </div>
                    </div>


                </form>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="main-card mb-3 card">
            <div class="card-body">

                <input type="button" data-editstatus="0" value="Save" class="btn btn-block btn-info" id="btnSaveCust" />

                <input type="button" value="Add New" class="btn btn-block btn-danger" id="btnAddNewCust" />

                <input type="button" value="Report" class="btn btn-block btn-gradient-success" id="btnReport" />



            </div>
        </div>

    </div>
</div>


<div class="row" id="showDiv">
    <div class="col-md-12">
        <div class="main-card mb-3 card">
