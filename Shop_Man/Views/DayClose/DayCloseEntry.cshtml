
@{
    ViewData["Title"] = "DayCloseEntry";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style type="text/css" media="print">
    @@page {
        size: auto; /* auto is the initial value */
        margin: 2mm 4mm 0mm 0mm; /* this affects the margin in the printer settings */
    }

    thead {
        display: table-header-group;
    }

    tfoot {
        display: table-footer-group;
    }
</style>
<style>
    input[type=text]:focus {
        background-color: #808080;
        color: white;
    }

    input[type=number]:focus {
        background-color: #808080;
        color: white;
    }
</style>
@section HeadingText {
    <div class="page-title-heading">
        <strong> ..::ডে ক্লোজ এন্ট্রি::..</strong>
        <div class="page-title-subheading">

        </div>
    </div>

}
<div class="row flex-sm-row">
    <div class="col-md-2">
        <label for="inputEmail3" class="col-form-label"> পূর্বের ডে ক্লোজ তারিখ :</label>

    </div>
    <div class="col-md-2">
        <input type="text" class="form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDateEntrySearch">
    </div>
    <div class="col-md-1">
        <button class="btn btn-dark" id="btnSearchdate"><i class="fa fa-search"></i></button>
    </div>

    <div class="col-md-2">
        <input class="btn btn-gradient-success" type="button" value="Edit or New Entry" id="btnEditorNewEntry" />
    </div>

    <div class="col-md-2">
        <input class="btn btn-danger" type="button" value="View Last Entry" id="btnLastEntry" />
    </div>

    <div class="col-sm-1">
        <input type="button" value="< Prev" class="btn btn-secondary " id="btnPrev" />
    </div>
    <div class="col-sm-1">
        <input type="button" value="Next >" class="btn btn-secondary" id="btnNext" />
    </div>
    <button type="button" class="btn  btn-primary" style="display:none;"
            data-toggle="modal" data-target="#modalInvoice" id="btnViewModel">
        Modal View
    </button>
    <button type="button" class="btn  btn-primary" style="display:none;"
            data-toggle="modal" data-target="#modalInvoiceSales" id="btnViewModel2">
        Modal View
    </button>
</div>


<div class="row">
    <div class="col-md-10">
        <div class="main-card mb-3 card">
            <div class="card-body">

                <form>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">সিরিয়াল নং :</label>
                        <div class="col-sm-3">
                            <input type="text" disabled class="form-control" id="txtInvoiceNo" />
                        </div>

                        <label for="inputEmail3" class="col-sm-2 col-form-label">ডে ক্লোজ তারিখ :</label>
                        <div class="col-sm-2">
                            <input type="text" disabled class="form-control" data-date-format="dd-mm-yyyy" id="txtDateEntry" />
                        </div>
                        <div class="col-sm-2">
                            <input type="text" disabled class="form-control" id="txtDateEntryTime" />
                        </div>
                    </div>


                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">পূর্বের ব্যাল্যান্স :</label>
                        <div class="col-sm-3">
                            <input disabled type="number" class="form-control" id="txtPrevBalance" />


                        </div>


                    </div>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">
                            মোট  গ্রহণ:
                        </label>
                        <div class="col-sm-3">
                            <input disabled type="number" class="form-control" id="txtTotalReceive" />


                        </div>
                        <div class="col-sm-2">
                            <input type="button" value="View Details" class="btn btn-gradient-info " id="btnRecvDetails" />


                        </div>

                    </div>

                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">মোট  প্রদান :</label>
                        <div class="col-sm-3">
                            <input disabled type="number" class="form-control" id="txtTotalPayment" />


                        </div>
                        <div class="col-sm-2">
                            <input type="button" value="View Details" class="btn btn-gradient-info " id="btnPayDetails" />


                        </div>

                    </div>

                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label"> Add/Less :</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" id="txtAddLess" />


                        </div>


                    </div>


                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label"> ব্যাল্যান্স :</label>
                        <div class="col-sm-3">
                            <input disabled type="number" class="form-control" id="txtBalance" />


                        </div>

