
@{
    ViewData["Title"] = "Cash Receive Entry";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style type="text/css" media="print">
    @@page {
        size: auto; /* auto is the initial value */
        margin: 2mm 4mm 0mm 0mm; /* this affects the margin in the printer settings */
    }

    thead {
        display: table-header-group;
    }

    tfoot {
        display: table-footer-group;
    }
</style>

<div class="row flex-sm-row">
    <div class="col-md-1">
        <label for="inputEmail3" class="col-form-label">তারিখ :</label>

    </div>

    <div class="col-md-2">
        <input type="text" disabled class="form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDateEntrySearch">
    </div>
    <div class="col-md-2">
        <label for="inputEmail3" class="col-form-label">প্রদানকারী :</label>
    </div>
    <div class="col-md-2">
        <input type="text" disabled class="form-control-sm form-control" id="txtCategorySearch" list="dltxtCategory" />
    </div>
    <div class="col-md-2">
        <input type="text" disabled class="form-control-sm form-control" id="txtSubCategorySearch" list="dltxtSubCategory" />
    </div>
    <div class="col-md-2">
        <input type="text" disabled class="form-control-sm form-control"  id="txtCustomerSearch" list="dltxtCustName" />
    </div>
    <div class="col-md-1">
        <button class="btn btn-dark" id="btnSearch"><i class="fa fa-search"></i></button>
    </div>
</div>


<div class="row">
    <div class="col-md-8">
        <div class="main-card mb-3 card">
            <div class="card-body">

                <form>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">ইনভয়েস নং  :</label>
                        <div class="col-sm-3">
                            <input type="text" disabled class="form-control" id="txtInvoiceNo">
                        </div>

                        <div class="col-sm-2">
                            <input type="text" disabled class="form-control" id="txtInvoiceNoSL">
                        </div>
                    </div>


                    <div class="form-group row">
                        <label for="inputPassword3" class="col-sm-2 col-form-label">তারিখ :</label>
                        <div class="col-sm-3">
                            <input type="text" autocomplete="off" data-date-format="dd-mm-yyyy" class="form-control" id="txtDate" placeholder="">

                        </div>

                        <div class="col-sm-3">
                            <input type="text" disabled class="form-control" autocomplete="off" id="txtDateTime" placeholder="">

                        </div>

                    </div>



                    <div class="form-group row">
                        <label for="inputPassword3" class="col-sm-2 col-form-label">ক্যাটাগরি :</label>
                        <div class="col-sm-4">
                            <input type="text" autocomplete="off" class="form-control" id="txtCategory" placeholder="" list="dltxtCategory" />
                            <datalist id="dltxtCategory">
                            </datalist>
                        </div>


                    </div>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">শপ নাম :</label>
                        <div class="col-sm-10">
                            <input type="text" autocomplete="off" class="form-control" id="txtCustomer" list="dltxtCustName" />
                            <datalist id="dltxtCustName"></datalist>
                        </div>
                    </div>


                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">প্রদানকারী নাম :</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control-sm form-control" disabled id="txtCustNameAddress" />

                        </div>
                    </div>

                 


                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">পূর্বের বাকী :</label>
                        <div class="col-sm-4">
                            <input type="number" disabled class="form-control" id="txtPrevDue">
                        </div>

                    </div>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">মাধ্যম :</label>
                        <div class="col-sm-4">
                            <input type="text" disabled class="form-control" id="txtMedium" />
                            <datalist id="dltxtMedium"></datalist>
                        </div>

                    </div>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">টাকা :</label>
                        <div class="col-sm-4">
                            <input type="text" class="form-control" id="txtAmount">
                        </div>

                    </div>

                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">নোট :</label>
                        <div class="col-sm-10">
                            <input type="text" autocomplete="off" class="form-control" id="txtNote">
                        </div>

                    </div>
                    <div class="form-group row">
                        <div class="col-sm-12">
                            <span id="spInfo">

                            </span>
                        </div>
                    </div>


                </form>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="main-card mb-3 card">
            <div class="card-body">

                <input type="button" data-cashReceiveID="0" value="Save" class="btn btn-block btn-info" id="btnSaveCust" />

                <input type="button" value="Add New" class="btn btn-block btn-danger" id="btnAddNewCust" />

            </div>
        </div>

    </div>
</div>

<div class="row" id="showDiv">
    <div class="col-md-12">
        <div class="main-card mb-3 card">
            <div class="card-body">
                <table style="width: 100%;" id="dataTable" class="table table-hover table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>সি নং</th>

                            <th>ইনভয়েস নং</th>
                            <th>তারিখ</th>
                            <th>প্রদানকারী</th>
                            <th>মাধ্যম</th>
                            <th>টাকা</th>
                            <th>নোট</th>
                            <th></th>
                            <th></th>
                        </tr>
                    </thead>

                </table>
            </div>
        </div>
    </div>
</div>

@section HeadingText {
    <div class="page-title-heading">
        ..::   ক্যাশ রিসিভ   ::..
        <div class="page-title-subheading">

        </div>
    </div>

}



<script type="text/javascript">
    var days = ['Saturday','Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday' ];
    var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    var specialChars = [
        '০',
        '১',
        '২',
        '৩',
        '৪',
        '৫',
        '৬',
