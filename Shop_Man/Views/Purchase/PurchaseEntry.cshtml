                        <td>    <input type="text"  autocomplete="off" class="form-control-sm form-control" id="txtSuppBilNo" />    </td>
                        <td>
                            <input type="button" data-purchaseheadid="0" data-purchasedetailsid="0" value="Save" class="btn  btn-info btn-block" id="btnSaveCust" />

                        </td>

                        <td>  </td>

                    </tr>
                </table>

            </div>

        </div>

    </div>


</div>

<div id="modalInvoice" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <input type="button" class="btn btn-outline-primary" value="Create PDF"
                       id="btPrint" onclick="createPDF()" />
            </div>
            <div class="modal-body" id="tab">
                <style>


                    .tblClass {
                        font-family: Trebuchet MS,Arial,Helvetica,sans-serif;
                        width: 100%;
                        font-size: 0.8em;
                        font-weight: normal;
                    }

                    .headerAllBorder {
                        border-right: 1px solid black;
                        border-left: 1px solid black;
                        border-top: 1px solid black;
                        font-size: 0.8em;
                        text-align: center;
                    }

                    .TDRightLeftBorder {
                        border-right: 1px solid black;
                        border-left: 1px solid black;
                        text-align: center;
                        font-size: 0.8em;
                    }

                    .TDAllBorder {
                        border-right: 1px solid black;
                        border-left: 1px solid black;
                        border-bottom: 1px solid black;
                        text-align: center;
                        font-size: 0.8em;
                    }

                    .headerRightBorder {
                        border-right: 1px solid black;
                        border-top: 1px solid black;
                        border-bottom: 1px solid black;
                        text-align: center;
                        font-size: 0.8em;
                    }

                    .TDRightBorder {
                        border-right: 1px solid black;
                        border-bottom: 1px solid black;
                        text-align: center;
                        font-size: 0.8em;
                    }
                </style>

                <table class="tblClass" id="tblOrderBill">
                    <thead>
                        <tr><td colspan="12" class="headerAllBorder" style="text-align:center;  font-size:16px; font-weight:bold;">PURCHASE INVOICE</td></tr>
                        <tr><td colspan="12" class="TDRightLeftBorder" style="text-align:center;  font-size:10px;font-weight:bold;"><span id="spHeaderBill"></span></td></tr>
                        <tr><td colspan="12" class="TDRightLeftBorder" style="text-align:center;  font-size:12px;"><span id="spAddressBill"></span></td></tr>
                        <tr><td colspan="12" class="TDRightLeftBorder" style="text-align:center;  font-size:12px;"><strong><span id="spAddressMobile"></span></strong></td></tr>
                        <tr>
                            <td colspan="2" style="text-align:left;  font-size:10px;  border-left: 1px solid black; font-weight:bold; padding:3px;">Invoice No :</td>
                            <td colspan="2" style="text-align:left;  font-size:10px;"><span id="spOrderNoBill"></span></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                          
                            <td colspan="2" style="text-align:right;  font-size:10px;font-weight:bold; padding:3px;">Date :</td>
                            <td colspan="2" style="text-align:right;  font-size:10px;border-right: 1px solid black;"><span id="spDateBill"></span></td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align:left;  font-size:10px;  border-left: 1px solid black;font-weight:bold; padding:3px;">Supplier Name :</td>
                            <td colspan="6" style="text-align:left;  font-size:10px; "><span id="spPartyBill"></span> </td>

                            <td colspan="2" style="        text-align: right;
        font-size: 10px;
        font-weight: bold;
        padding: 3px;">Supplier Bill No :</td>
                            <td colspan="2" style="text-align:right;  font-size:10px; border-right: 1px solid black;"><span id="spSuppBillNo"></span></td>



                        </tr>
                        <tr>
                            <td colspan="2" style="text-align:left;  font-size:10px;  border-left: 1px solid black;font-weight:bold; padding:3px;">Contact Person :</td>
                            <td colspan="10" style="text-align:left;  font-size:10px; border-right: 1px solid black;"><span id="spContactPerson"></span></td>

                        </tr>
                        <tr>
                            <td colspan="2" style="        text-align: left;
        font-size: 10px;
        border-left: 1px solid black;
        font-weight: bold;
        padding: 3px;
        border-bottom: 1px solid black;"> Address :</td>
                            <td colspan="10" style="        text-align: left;
        font-size: 10px;
        border-right: 1px solid black;
        border-bottom: 1px solid black;"><span id="spPartyshopAddressBill"></span></td>

                        </tr>
                    
                    </thead>
                    <tr>
                        <td class="TDAllBorder" style="width:5%">
                            সি নং
                        </td>
                        <td class="TDRightBorder" style="width:10%">পণ্যের নাম</td>
                        <td class="TDRightBorder" style="width:10%">
                            আর্টিকেল
                        </td>
                        <td class="TDRightBorder" style="width:10%">সাইজ</td>
                        <td class="TDRightBorder" style="width:10%">জোড়া/ডজন</td>
                        <td class="TDRightBorder" style="width:6%">ডজন</td>
                        <td class="TDRightBorder" style="width:6%">জোড়া</td>
                        <td class="TDRightBorder" style="width:7%">ক্রয় মূল্য</td>
                        <td class="TDRightBorder" style="width:7%">কমিঃ</td>
                        <td class="TDRightBorder" style="width:10%"> মোট ক্রয় মূল্য</td>
                        <td class="TDRightBorder" style="width:10%"> মোট কমিঃ</td>
                        <td class="TDRightBorder" style="width:10%">	নীট  ক্রয় মূল্য</td>
                    </tr>


                </table>
            </div>

        </div>
    </div>
</div>
