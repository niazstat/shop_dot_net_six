
@{
    ViewData["Title"] = "PurchaseEntry";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style type="text/css" media="print">
    @@page {
        size: auto; /* auto is the initial value */
        margin: 2mm 4mm 0mm 0mm; /* this affects the margin in the printer settings */
    }

    thead {
        display: table-header-group;
    }

    tfoot {
        display: table-footer-group;
    }
</style>
<style>
    input[type=text]:focus {
        background-color: #808080;
        color: white;
    }

    input[type=number]:focus {
        background-color: #808080;
        color: white;
    }
</style>
@section HeadingText {
    <div class="page-title-heading text-dark text-center">
        .:: ক্রয় এন্ট্রি ::.
    </div>

}
<script src="~/js/views/purchase/purchaseentry.js"></script>

<div class="row flex-sm-row">
    <div class="col-md-12">

        <div class="main-card mb-3 card" style=" margin-bottom: 0em !important;">
            <div class="card-body">
                <form>
                    <div class="form-row">
                        <label for="inputEmail3" class="col-sm-1 col-form-label">বিল নম্বর:</label>
                        <div class="col-sm-2">
                            <input type="text" class="mb-2 form-control-sm form-control" id="txtBIllNo">
                        </div>
                        <div class="col-sm-1">
                            <input type="button" value="Edit" class="btn btn-danger btn-block" id="btnEdit" />
                        </div>
                        <div class="col-sm-1">
                            <input type="button" value="View"  data-toggle="modal" data-target="#modalInvoice" class="btn btn-dark btn-block" id="btnView" />
                          
                        </div>
                        <div class="col-sm-1">
                            <input type="button" value="< Prev" class="btn btn-secondary " id="btnPrev" />
                        </div>
                        <div class="col-sm-1">
                            <input type="button" value="Next >" class="btn btn-secondary" id="btnNext" />
                        </div>
                        <div class="col-sm-1">
                            <input type="button" value="Add New" class="btn btn-danger btn-block" id="btnAddNewCust" />
                        </div>
                          
                            <label for="inputEmail3" class="col-sm-1 col-form-label">এন্ট্রি তারিখ:</label>
                            <div class="col-sm-2">
                                <input type="text" disabled class="mb-1 form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDateEntry">
                            </div>
