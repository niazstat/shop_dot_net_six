            <div class="col-sm-2">
                <input type="text" data-tab="2" class="form-control-sm form-control" id="txtSubCategory" placeholder="" list="dltxtSubCategory">
                <datalist id="dltxtSubCategory">
                </datalist>
            </div>*@




                        </div>

                        <div class="form-row">

                            <label for="inputEmail3" class="col-sm-1 col-form-label">তারিখ:</label>
                            <div class="col-sm-2">
                                <input data-tab="2" type="text" class="mb-1 form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDate">
                            </div>

                            <label for="inputPassword3" class="col-sm-1 col-form-label">Category</label>
                            <div class="col-sm-2">
                                <input type="text" data-tab="3" class="form-control-sm form-control" id="txtCategory" placeholder="" list="dltxtCategory">
                                <datalist id="dltxtCategory">
                                </datalist>
                            </div>






                            <label for="inputEmail3" class="col-sm-2 col-form-label"> বিক্রেতার নাম:</label>
                            <div class="col-sm-4">
                                <input data-tab="4" type="text" autocomplete="off" class="form-control-sm form-control" id="txtSupplierName" list="dltxtSupplierName" />
                                <datalist id="dltxtSupplierName"></datalist>
                            </div>


                        </div>


                        <div class="form-row">

                            <div class="col-md-2">

                                <label for="exampleCity">পণ্যের নাম</label>
                                <input data-tab="5" autocomplete="off" name="city" id="txtProName" type="text" class="form-control-sm form-control" list="dltxtProName" />
                                <datalist id="dltxtProName"></datalist>

                            </div>
                            <div class="col-md-2">

                                <label for="exampleCity">আর্টিকেল</label>
                                <input data-tab="6" autocomplete="off" name="city" id="txtArcticle" type="text" class="form-control-sm form-control" list="dltxtArcticle" />
                                <datalist id="dltxtArcticle"></datalist>
                            </div>

                            <div class="col-md-2">

                                <label for="exampleCity">সাইজ</label>
                                <input autocomplete="off" name="city" id="txtSize" disabled type="text" class="form-control-sm form-control" list="dltxtSize" />
                                <datalist id="dltxtSize"></datalist>
                            </div>

                            <div class="col-md-2">

                                <label for="exampleCity">জোড়া/ডজন</label>
                                <input autocomplete="off" disabled name="city" id="txtUOM" type="text" class="form-control-sm form-control" list="dltxtUOM" />
                                <datalist id="dltxtUOM"></datalist>
                            </div>
                            <div class="col-md-2">
                                <label for="exampleCity">Currrent Tock</label>
                                <input disabled autocomplete="off" name="city" id="txtCurrentStock" type="text" class="form-control-sm form-control" />
                            </div>
                            <div class="col-md-2">
                                <label for="exampleCity">Sell price</label>
                                <input disabled autocomplete="off" name="city" id="txtSellPrice" type="text" class="form-control-sm form-control" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="col-md-2">

                                <label for="exampleCity">জোড়া</label>
                                <input data-tab="7" min="0" autocomplete="off" name="city" id="txtPair" type="text" class="form-control-sm form-control" />
                            </div>
                            <div class="col-md-1">

                                <label for="exampleCity">ডজন</label>
                                <input disabled min="0" autocomplete="off" name="city" id="txtDozen" type="text" class="form-control-sm form-control" />
                            </div>
                            <div class="col-md-2">

                                <label for="exampleCity">কমিঃ</label>
                                <input data-tab="8" min="0" autocomplete="off" name="city" id="txtComm" type="text" class="form-control-sm form-control" />
                            </div>
                            <div class="col-md-2">

                                <label for="exampleCity">ক্রয় মূল্য</label>
                                <input data-tab="9" min="0" autocomplete="off" name="city" id="txtBuyPrice" type="text" class="form-control-sm form-control" />
                            </div>
                            <div class="col-md-2">

                                <label for="exampleCity">মোট ক্রয় মূল্য</label>
                                <input min="0" autocomplete="off" name="city" disabled id="txtTotalBuyPrice" type="text" class="form-control-sm form-control" />
                            </div>
                            <div class="col-md-2">

                                <label for="exampleCity">মোট কমিঃ</label>
                                <input min="0" autocomplete="off" name="city" disabled id="txtTotalComm" type="text" class="form-control-sm form-control" />
                            </div>

                            <div class="col-md-1">

                                <label for="exampleCity"></label>
                                <br />
                                <input type="button" data-tab="10" data-purchaseheadid="0" data-purchasedetailsid="0" data-companyProductID="0" data-slno="0" value="Add" class="btn btn-success" id="btnAdd" />

                            </div>

                            <div class="col-sm-2">
                                <label for="exampleCity"></label>
                                <br />

                            </div>

                        </div>
                        <div class="form-group row">
                            <div class="col-sm-12">
                                <span id="spInfo">

                                </span>
                            </div>
                        </div>
</form>
            </div>

        </div>

    </div>


</div>

<div class="row flex-sm-row">
    <div class="col-md-12" style="padding-top:0em; padding-bottom:0em;">

        <div class="main-card mb-3 card" style=" margin-bottom: 0em !important;">
            <div class="card-body">


                <table id="tblProdItem" class="table table-sm table-bordered" style="margin-bottom:0 !important ">
                    <thead>
                        <tr>
                            <th style="display:none">CommProductID</th>
                            <th>সি নং</th>
                            <th>পণ্যের নাম</th>
                            <th>আর্টিকেল</th>

                            <th>সাইজ</th>
                            <th>Stock</th>
                            <th>জোড়া/ডজন</th>
                            <th>ডজন</th>
                            <th>জোড়া</th>
                            <th>ক্রয় মূল্য</th>
                            <th> কমিঃ</th>

                            <th>মোট ক্রয় মূল্য</th>
                            <th>কোঃ কমিঃ</th>

                            <th>

                            </th>
                            <th>


                            </th>
                        </tr>




                    </thead>
                </table>


                <table class="table table-sm table-info">

                    <tr>
                        <td>Total Dozen:</td>
                        <td> <input type="number" disabled autocomplete="off" class="form-control-sm form-control" id="txtTotalDozen" /></td>
                        <td></td>
                        <td></td>
                        <td> Total Amount</td>

                        <td> <input type="number" disabled autocomplete="off" class="form-control-sm form-control" id="txtTotalAmount" /></td>
                        <td> Previous Due:</td>

                        <td> <input type="number" disabled autocomplete="off" class="form-control-sm form-control" id="txtPrevDue" /></td>

                    </tr>


                    <tr>
                        <td>Total Pair:</td>
                        <td> <input type="number" disabled autocomplete="off" class="form-control-sm form-control" id="txtTotalpair" /></td>

                        <td> Total Commission</td>

                        <td> <input type="number" disabled autocomplete="off" class="form-control-sm form-control" id="txtTotalComm2" /></td>
                        <td> Neat Amount</td>
                        <td> <input type="number" disabled autocomplete="off" class="form-control-sm form-control" id="txtNeatAmount" /></td>
                        <td> Total Due:</td>

                        <td> <input type="number" disabled autocomplete="off" class="form-control-sm form-control" id="txtPrevDue" /></td>
                    </tr>

                    <tr>
