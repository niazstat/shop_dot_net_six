                    render: function (data, type, row) {
                        return data.supplier == null ? '( Cust) ' + data.customer.shopName : '( Supp) ' + data.supplier.name;
                    }
                },

            
                { "data": "amount" },
                { "data": "closingShortAmount" },
                { "data": "rejectGoodsAmount" },
                { "data": "note" },


                {
                    "data": null,
                    "mRender": function (data, type, full) {
                        return '<button class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-info" onclick="editCustomer(\'' + data.adjustmentID + '\')">Edit</button>';
                    }
                },
                {
                    "data": null,
                    "mRender": function (data, type, full) {
                        return '<button class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-danger" onclick="deleteCustomer(\'' + data.adjustmentID + '\')">Delete</button>';
                    }
