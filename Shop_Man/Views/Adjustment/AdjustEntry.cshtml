            autoclose: true,
        });
        $("#txtDateEntrySearch").val(today);
        $("#txtDate").val(today);
        LoadDefaultData();

        function ChangeDt(caller) {

            console.log(caller);
            let _thisVal2 = $(caller).val();

            if (_thisVal2.indexOf('-') > 0) {

                let _existValue = _thisVal2.split('-');
                console.log(_existValue);
                $(caller).val(_existValue[0] + '-' + months[_existValue[1] - 1] + '-' + _existValue[2]);

            }
        };

        function LoadDefaultData() {
            //ClearControl();
            $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                url: WEB_URL + "Adjustment/GetAdjustmentEntryViewModel",

                // data: JSON.stringify(receiveMain),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();
                    $("#spInfo").html('');
                    console.log(data);

                    SUPP_LIST = data.suppliers;
                    CUST_LIST = data.customers;
                    SUPP_SUBCAT_LIST = data.supplierSubCategorys;
                    CUST_SUBCAT_LIST = data.customerSubCategorys;
              

                    tableCust.rows.add(data.adjustments).draw();

                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });
        }


        $('#selCustSuppType').on('change', function () {
            $("#dltxtCustSuppSubCat option").remove();

            $("#txtCustSuppSubCat").val('');

            $("#dltxtCustName option").remove();
            $("#txtCustomer").val('');
            let _val = this.value;

            LoadNames(_val);

        });

        function LoadNames(_val) {

            if (_val == "Customer") {
                BindCustomersSubCat();
                // LoadCustomers();
            }
            else if (_val == "Supplier") {
                // LoadSuppliers();
                BindSuppliersSubCat();
            }

        }



        function BindCustomersSubCat() {
            $("#dltxtCustSuppSubCat option").remove();
            $.each(CUST_SUBCAT_LIST, function (i, prodData) {
                $("#dltxtCustSuppSubCat").append(' <option  data-custsubcatid="' + prodData.customerSubCategoryID + '" value="' + prodData.customerSubCategoryName + '" />');

            });
        }


        function BindSuppliersSubCat() {
            $("#dltxtCustSuppSubCat option").remove();
            $.each(SUPP_SUBCAT_LIST, function (i, prodData) {
                $("#dltxtCustSuppSubCat").append(' <option  data-suppsubcatid="' + prodData.supplierSubCategoryID + '" value="' + prodData.supplierSubCategoryName + '" />');

            });
        }



        // GetSubCatID(value, dataList, attrName) {


        $("#txtCustSuppSubCat").on('input', function () {

            $("#txtRevBalance").val('');
            $("#dltxtCustName option").remove();
            $("#txtCustomer").val('');

            let _subCatName = $("#txtCustSuppSubCat").val();

            var _suppsubCatid = GetSubCatID(_subCatName, "#dltxtCustSuppSubCat", 'data-suppsubcatid');
            var _custsubCatid = GetSubCatID(_subCatName, "#dltxtCustSuppSubCat", 'data-custsubcatid');

            if (_suppsubCatid != '0') {
                BindSuppName(_suppsubCatid);
            }
            else if (_custsubCatid != '0') {
                BindCustName(_custsubCatid)
            }
            else {
                $("#dltxtCustName option").remove();
            }


        });


        $("#btnSaveCust").click(function () {
            $("#spInfo").html('');

            let _adjustmentID = $(this).attr('data-adjustmentID');
         
            let _receivedate = $("#txtDate").val();
            let _payName2 = $("#txtMedium").val();
        
            let _custName = $("#txtCustomer").val();



            var _cstID = GetSubCatID(_custName, "#dltxtCustName", 'data-custID');
            var _suppID = GetSubCatID(_custName, "#dltxtCustName", 'data-suppID');




            let _amount = ConvertBanglaToEnglish($("#txtAmount").val());
            let _shortAmount = ConvertBanglaToEnglish($("#txtCLosingShortAmount").val());
            let _rejAmount = ConvertBanglaToEnglish($("#txtRejectAmount").val());

            let _note1 = $("#txtNote").val();


   

            if ((_cstID == null || _cstID == undefined || _cstID == '0') && (_suppID == null || _suppID == undefined || _suppID == '0')) {


                $("#spInfo").html('<strong style="color:red">Invalid Customer/Supplier !</strong>');

                $("#txtCustName").focus();
                return;

            }





            let _cust = {};

            let _supp = {};

            if (_cstID != "0") {

                _cust = {
                    "CustomerID": parseInt(_cstID)
                };

            }
            else if (_suppID != "0") {
                _supp = {
                    "SupplierId": parseInt(_suppID)
                };


            }


            if (_amount == '') {
                _amount = '0';
            }
            if (_shortAmount == '') {
                _shortAmount = '0';
            }
            if (_rejAmount == '') {
                _rejAmount = '0';
            }


 


            var adjustment = {
                "AdjustmentID": _adjustmentID,
                "PaymentDate": _receivedate,
                "Supplier": _supp,
                "Customer": _cust,
         

                "Note": _note1,
                "Amount": parseFloat(_amount),
                "ClosingShortAmount": parseFloat(_shortAmount),
                "RejectGoodsAmount": parseFloat(_rejAmount)
            }

            // console.log(cashReceive);




            $("#spInfo").html('<strong style="color:blue">Savng Data Please wait.. !</strong>');



            $.ajax({
                type: "POST",
                url: WEB_URL + "Adjustment/SaveAdjustment",

                data: JSON.stringify(adjustment),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    console.log(data);
                    if (parseInt(data.resultID) > 0) {
                        $("#txtInvoiceNo").val(data.resultNo);
                        $("#spInfo").html('<strong style="color:blue">' + data.resultMessage + '</strong>');
                        ClearControlAfterSave();
                        tableCust.clear().draw();
                        tableCust.rows.add(data.obj).draw();

                    }
                    else {
                        // HideGateOverlay();
                        $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                    }


                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });




        });





        $("#txtCustomer").on('input', function () {

            $("#txtPrevDue").val('');

            let _custName = $("#txtCustomer").val();

            if (_custName == '') {
                return;
            }


            var _cstID = GetSubCatID(_custName, "#dltxtCustName", 'data-custID');
            var _suppID = GetSubCatID(_custName, "#dltxtCustName", 'data-suppID');





            if ((_cstID == null || _cstID == undefined || _cstID == '0') && (_suppID == null || _suppID == undefined || _suppID == '0')) {
                return;
            }

            let _cust = {};

            let _supp = {};
            let _url = "";
            let _obj = {}
            if (_cstID != "0") {

                _cust = {
                    "CustomerID": parseInt(_cstID)
                };
                _url = WEB_URL + "Customer/GetCustomerCurrentBalalce";
                _obj = _cust;
            }
            else if (_suppID != "0") {
                _supp = {
                    "SupplierId": parseInt(_suppID)
                };

                _url = WEB_URL + "Supplier/GetSupplierCurrentBalalce";
                _obj = _supp;
            }

            $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');



            $.ajax({
                type: "POST",
                data: JSON.stringify(_obj),
                url: _url,
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();

                    console.log(data);
                    $("#txtPrevDue").val(data.currentBalance);

                    $("#spInfo").html('');

                    // BindSuppliers(data);


                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });




        });




        function ClearControlAfterSave() {

            $("#txtCustomer").val('');
            $("#txtPrevDue").val('0');
            $("#txtAmount").val('0');
            $("#txtCLosingShortAmount").val('0');
            $("#txtRejectAmount").val('0');
            $("#txtNote").val('');
            $("#btnSaveCust").removeAttr('disabled');
            $("#btnSaveCust").val('Save');
            $("#btnSaveCust").attr('data-adjustmentID', '0');

        }



        function GetDataValue(value, dataList) {
            var z = $(dataList);
            var val = $(z).find('option[data-id="' + value + '"]');
            var endval = val.attr('value');
            return endval;
        }
        function GetDataID(value, dataList) {
            var z = $(dataList);
            var val = $(z).find('option[value="' + value + '"]');
            var endval = val.attr('data-id');
            return endval;
        }

        function GetSubCatID(value, dataList, attrName) {
            var z = $(dataList);
            var val = $(z).find('option[value="' + value + '"]');
            var endval = val.attr(attrName);
            return endval == undefined ? 0 : endval;
        }

    });




    function editCustomer(id) {
        // ClearControl();

        var cashPayment = {
            "adjustmentID": id
        }
        // alert(id);
        $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + "Adjustment/GetAdjustment",

            data: JSON.stringify(cashPayment),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);
                if (parseInt(data.resultID) == -1) {
                    $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                }
                else {
                    $("#spInfo").html(data.resultMessage);
                    $("#btnSaveCust").val('Update');
                    $("#btnSaveCust").attr('data-adjustmentID', data.obj.adjustmentID);

                    $("#txtDate").val(data.obj.paymentDateDateFormated);

                    if (data.obj.supplier != null) {
                        $("#txtCustomer").val(data.obj.supplier.name);
                        BindSuppName(data.obj.supplier.supplierSubCategoryID);

                    }

                    else if (data.obj.customer != null) {
                        $("#txtCustomer").val(data.obj.customer.shopName);
                        BindCustName(data.obj.customer.customerSubCategoryID);

                    }
                    $("#txtAmount").val(data.obj.amount);
                    $("#txtCLosingShortAmount").val(data.obj.closingShortAmount);

                    $("#txtRejectAmount").val(data.obj.rejectGoodsAmount);
                    $("#txtNote").val(data.obj.note);
                }



            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });



    }

    function deleteCustomer(id) {

        // ClearControl();

        if (confirm('Are you sure to delete Customer?')) {
            // Save it!
            console.log('Thing was saved to the database.');
        }
        else {
            return;
        }




        var cashPayment = {
            "adjustmentID": id
        }

        //alert(id);
        $("#spInfo").html('<strong style="color:blue"> Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + "Adjustment/DeleteAdjustment",

            data: JSON.stringify(cashPayment),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);



                if (parseInt(data.resultID) == -1) {
                    $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');

                }
                else {
                    //ClearControl();
                    $("#spInfo").html('<strong style="color:green">' + data.resultMessage + '</strong>');


                    //ClearControlAfterSave();
                    tableCust.clear().draw();
                    tableCust.rows.add(data.obj).draw();

                }





                $("#spInfo").html('');

            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });

    }


    function BindCustName(_id) {
        $("#dltxtCustName option").remove();


        var filterednames = CUST_LIST.filter(function (obj) {
            return (obj.customerSubCategoryID == _id);
        });


        console.log(CUST_LIST);
        $.each(filterednames, function (i, prodData) {

            $("#dltxtCustName").append(' <option  data-custID="' + prodData.customerID + '" value="' + prodData.shopName + '" />');


        });

    }



    function BindSuppName(_id) {
        $("#dltxtCustName option").remove();



        var filteredSuppnames = SUPP_LIST.filter(function (obj) {
            return (obj.supplierSubCategoryID == _id);
        });
        console.log(SUPP_LIST);
        $.each(filteredSuppnames, function (i, prodData) {

            $("#dltxtCustName").append(' <option  data-suppID="' + prodData.supplierId + '" value="' + prodData.name + '" />');


        });

    }

</script>


