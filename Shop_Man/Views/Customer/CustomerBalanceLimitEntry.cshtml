</div>



<div id="modalSubCategory" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLongTitle">Add Sub Category</h5>
                <button type="button" class="close reset" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="signupForm" class="col-md-12 mx-auto">
                    <input name="partyCode" id="partyCode" type="hidden" class="form-control">
                    <div class="form-row">
                        <div class="col-md-6">
                            <div class="position-relative form-group">
                                <label for="customerName">Category Name</label>
                                <input name="CategoryName" id="txtCatNameEditSub" placeholder="Category Name" type="text" class="form-control" list="dltxtCategory">
                                <em id="concernNameBengali-error" class="error invalid-feedback">Please enter name</em>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="position-relative form-group">
                                <label for="customerName">Sub Category Name</label>
                                <input name="CategoryName" id="txtSubCatNameEditSub" placeholder="Sub Category Name" type="text" class="form-control">
                                <em id="concernNameBengali-error" class="error invalid-feedback">Please enter name</em>
                            </div>
                        </div>

                    </div>


                    <div class="form-row">
                        <div class="col-md-6">
                            <span id="spInfo3">

                            </span>
                        </div>
                        <div class="col-md-6">

                            <input data-subcatId="0" type="button" id="btnSaveSubCat" class="btn btn-success" value="Save" />
                        </div>
                    </div>

                    <div class="form-row">

                        <div class="col-md-12">
                            <table style="width: 100%;" id="tblSubCat" class="table table-hover table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Category</th>
                                        <th>Sub Category</th>
                                        <th></th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>





                </form>
            </div>
            <div class="modal-footer">
                <button type="button" id="modalCloseSubCat" class="btn btn-outline-secondary reset" data-dismiss="modal">Close</button>

            </div>
        </div>
    </div>
</div>


<script type="text/javascript">

    var CUST_LIST = [];
    var CUST_CAT = [];
    var SUB_CUST_CAT = [];
    var tableCust;
    $(document).ready(function () {

        // alert('ghgh');

        LoadDefaultData();


        tableCust = $('#dataTable').DataTable({
            data: [],
            "columnDefs": [

                {
                    "searchable": true,
                    "orderable": false,
                    "targets": 0
                }
            ],
            "language":
            {
                "processing": '<div class="font-icon-wrapper float-left mr-3 mb-3" style="margin-left: 9%;">' +
                    '<div class="loader-wrapper d-flex justify-content-center align-items-center">' +
                    '<div class="loader">' +
                    '<div class="line-scale-pulse-out-rapid">' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '</div>' +
                    '</div>' +
                    '</div>' +
                    '<p>Loading</p></div>'
            },
            //"responsive": true,
            //"processing": true,
            //"serverSide": true,
            "lengthMenu": [
                [10, 15, 25, 50, 100, -1],
                [10, 15, 25, 50, 100, "All"]
            ],

            "order": [1, "asc"],
            "start": 0,
            "length": 10,
            "bFilter": true,


                 

            "columns": [
                { "data": "customerID" },
                { "data": "customerNo" },
                
                { "data": "name" },
                { "data": "shopName" },
                { "data": "openingBalance" },
                { "data": "district.name" },
                { "data": "mobileNo" },
                { "data": "maxBalanceLimit" },

                {
                    "data": null,
                    "mRender": function (data, type, full) {
                        return '<button class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-info" onclick="editCustomer(\'' + data.customerID + '\')">Edit Limit</button>';
                    }
                }
                
            ]
        });



        $("input").on('keypress', function (event) {

            // alert('ok');
            var _currentTab = $(this).attr("data-tab");
            var _id = $(this).attr("id");

            var keycode = (event.keyCode ? event.keyCode : event.which);
            if (keycode == '13') {
                if (_currentTab != undefined) {
                    if (_id !== 'btnSaveCust') {
                        var _nextTab = parseInt(_currentTab) + 1;
                        $('input[data-tab="' + _nextTab + '"]').focus();
                    }
                }
            }


        });




        function LoadDefaultData() {
            ClearControl();
            $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                url: WEB_URL + "Customer/CustomerEntryViewModel",

                // data: JSON.stringify(receiveMain),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();
                    $("#spInfo").html('');
                    console.log(data);
                    //RECEIVE = data;
                    //BindProduct(data);
                    //$("#spInfo").html('');
                   // CUST_CAT = data.customerCategorys;
                    CUST_LIST = data.customers;
                   // SUB_CUST_CAT = data.customerSubCategorys;
                   // LoadCustCategoryName(data.customerCategorys);
                   // BinCategoryTable(data.customerCategorys);
                   // BindDistrictName(data.districtS);
                   // BinSubCategoryTable(data.customerSubCategorys);
                    tableCust.rows.add(data.customers).draw();

                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });
        }
      
   

        $("#btnSaveCust").on('click', function () {

            $("input").each(function () {
                $(this).removeClass("input-validation-error");
            });
            $("#spInfo").html('');


            var _custId = $("#btnSaveCust").attr('data-custid');

            var _opPcs = $("#txtMaxBalLimit").val();


            if (_custId == '' || _custId=='0') {
                $("#txtCustName").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Customer  !</strong>');
                return;
            }
        

            if (_opPcs == '') {
                $("#txtMaxBalLimit").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Balance Limit !</strong>');
                return;
            }


            if (_opPcs == '') {
                _opPcs = '0';
            }


            $("#spInfo").html('<strong>Please wait ....</strong>');
            var customer = {
                "CustomerID": _custId,
                "MaxBalanceLimit": _opPcs
         

            }
            $.ajax({
                type: "POST",
                url: WEB_URL + "Customer/UpdateCustomerLimit",

                data: JSON.stringify(customer),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();

                    console.log(data);

                    if (parseInt(data.resultID) == -1) {
                        $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');

                    }
                    else {
                        ClearControl();
                        $("#spInfo").html('<strong style="color:green">' + data.resultMessage + '</strong>');
                        CUST_LIST = data.obj;
                        // tableCust.fnClearTable();
                        tableCust.clear().draw();
                        tableCust.rows.add(data.obj).draw();

                    }




                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });



        });



     

        $("#btnAddNewCust").on('click', function () {
            ClearControl();
        });

      
        /////////////-------------

        function GetDataValue(value, dataList) {
            var z = $(dataList);
            var val = $(z).find('option[data-id="' + value + '"]');
            var endval = val.attr('value');
            return endval;
        }
        function GetDataID(value, dataList) {
            var z = $(dataList);
            var val = $(z).find('option[value="' + value + '"]');
            var endval = val.attr('data-id');
            return endval;
        }





    });

    function editCustomer(id) {
        ClearControl();
        var customer = {
            "CustomerID": id
        }


        $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + "Customer/GetCustomer",

            data: JSON.stringify(customer),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);
                $("#btnSaveCust").val('Update');
                $("#btnSaveCust").attr('data-custid', data.customerID);
                $("#txtCustCode1").val(data.customerNo);
                $("#txtCustName").val(data.name);
                $("#txtShopName").val(data.shopName);
                $("#txtMobile1").val(data.mobileNo);
                $("#txtMobile2").val(data.mobileNo2);
                $("#txtAddress").val(data.address1);
                $("#txtMaxBalLimit").val(data.maxBalanceLimit);



                $("#spInfo").html('');





    


            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });



    }




    function ClearControl() {
        $("#btnSaveCust").val('Save');
        $("#txtCategory").val('');
        $("#txtSubCategory").val('');

        $("#txtShopName").val('');

        $("#txtCustName").val('');

        $("#txtDistrict").val('');
        $("#txtDistrictNameEdit").val('');

        $("#txtAddress").val('');

        $("#txtMobile1").val('');

        $("#txtMobile2").val('');

        $("#txtCatNameEdit").val('');
        $("#txtCatNameEditSub").val('');

        $("#txtSubCatNameEditSub").val('');

        $("#txtOpBalance").val('0');

        $("#txtMaxBalLimit").val('0');
       
        $("#btnSaveCust").attr('data-custid', '0');
 

 




    }

</script>

