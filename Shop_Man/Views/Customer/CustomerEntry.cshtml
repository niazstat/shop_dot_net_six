    function editCustomer(id) {
        ClearControl();
        var customer = {
            "CustomerID": id
        }


        $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + "Customer/GetCustomer",

            data: JSON.stringify(customer),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);
                $("#btnSaveCust").val('Update');
                $("#btnSaveCust").attr('data-custid', data.customerID);
                $("#txtCustCode1").val(data.customerNo);
                $("#txtCustName").val(data.name);
                $("#txtShopName").val(data.shopName);
                $("#txtMobile1").val(data.mobileNo);
                $("#txtMobile2").val(data.mobileNo2);
                $("#txtAddress").val(data.address1);
                $("#txtOpBalance").val(data.openingBalance);


                $("#txtOpComm").val(data.openingCommission);
                $("#txtOpPcs").val(data.openingQty);

                $("#txtDistrict").val(data.district.name);

                console.log(data.customerSubCategoryID);
                var subCat = SUB_CUST_CAT.find(a => a.customerSubCategoryID == data.customerSubCategoryID);
                console.log(subCat);
                // $("#txtCategory").val();

                var _catName = subCat.customerCategory.customerCategoryName;
                var _catID = subCat.customerCategoryID
                $("#txtSubCategory").val(subCat.customerSubCategoryName);
                $("#txtCategory").val(_catName);



                $("#selStartingYear").val(data.startingYear);

                $("#selActiveStatus").val(data.isBlocked);
            
                $("#spInfo").html('');





                if (_catID != undefined) {
                    var _SubCatList = SUB_CUST_CAT.filter(function (_obj) {
                        return _obj.customerCategoryID == _catID;
                    });

                    LoadSubCustName(_SubCatList);
                }


            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });



    }

