.
@{
    ViewData["Title"] = "CustomerEntry";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section HeadingText {
    <div class="page-title-heading">
        New Customer Entry
        <div class="page-title-subheading">

        </div>
    </div>

}



<style>
    input[type=text]:focus {
        background-color: #282727;
        color: white;
    }

    input[type=number]:focus {
        background-color: #282727;
        color: white;
    }
</style>

<div class="row">
    <div class="col-md-10">
        <div class="main-card mb-3 card">
            <div class="card-body">
                <h5 class="card-title text-center">..::Customer Information Entry ::..</h5>

                <form>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">Customer Code :</label>
                        <div class="col-sm-6">
                            <input type="text" disabled class="form-control" id="txtCustCode1">
                        </div>

                        <div class="col-sm-4">
                            <input type="text" disabled class="form-control" id="txtCustCode2">
                        </div>
                    </div>


                    <div class="form-group row">
                        <label for="inputPassword3" class="col-sm-2 col-form-label">Category</label>
                        <div class="col-sm-3">
                            <input data-tab="1" type="text" class="form-control" id="txtCategory" placeholder="" list="dltxtCategory">
                            <datalist id="dltxtCategory">
                            </datalist>
                        </div>
                        <div class="col-sm-1">

                            <button type="button" class="btn  btn-primary"
                                    data-toggle="modal" data-target="#modalCategory" id="btnEditCat">
                                Edit
                            </button>

                        </div>


                        <label for="inputPassword3" class="col-sm-2 col-form-label">Sub Category</label>
                        <div class="col-sm-3">
                            <input data-tab="2" type="text" class="form-control" id="txtSubCategory" placeholder="" list="dltxtSubCategory">
                            <datalist id="dltxtSubCategory">
                            </datalist>
                        </div>
                        <div class="col-sm-1">
                            <button type="button" class="btn  btn-primary"
                                    data-toggle="modal" data-target="#modalSubCategory" id="btnEditSubCat">
                                Edit
                            </button>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">Shop Name</label>
                        <div class="col-sm-10">
                            <input data-tab="3" type="text" class="form-control" id="txtShopName" placeholder="">
                        </div>
                    </div>

                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">Customer Name</label>
                        <div class="col-sm-10">
                            <input data-tab="4" type="text" class="form-control" id="txtCustName" placeholder="">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">District</label>
                        <div class="col-sm-4">
                            <input data-tab="5" type="text" class="form-control" id="txtDistrict" list="dltxtDistrict" />


                            <datalist id="dltxtDistrict">
                            </datalist>
                        </div>
                        <div class="col-sm-1">

                            <button type="button" class="btn  btn-info"
                                    data-toggle="modal" data-target="#modalDistrict" id="btnEditDistrict">
                                Edit
                            </button>


                        </div>
                    </div>


                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">Address</label>
                        <div class="col-sm-10">
                            <input data-tab="6" type="text" class="form-control" id="txtAddress">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-2 col-form-label">Mobile 1</label>
                        <div class="col-sm-4">
                            <input data-tab="7" type="text" class="form-control" id="txtMobile1">
                        </div>
                        <label for="inputEmail3" class="col-sm-2 col-form-label">Mobile 2</label>
                        <div class="col-sm-4">
                            <input data-tab="8" type="text" class="form-control" id="txtMobile2">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-4 col-form-label">Op Balance ( Balance | Commission | PCs)</label>
                        <div class="col-sm-3">
                            <input data-tab="9" type="number" disabled class="form-control" id="txtOpBalance" placeholder=" Op Balance">
                        </div>

                        <div class="col-sm-2">
                            <input data-tab="10" type="number" disabled class="form-control" id="txtOpComm" placeholder=" Op Comm">
                        </div>
                        <div class="col-sm-2">
                            <input data-tab="11" type="number" disabled class="form-control" id="txtOpPcs" placeholder=" Op Qty">
                        </div>
                    </div>

                    <div class="form-group row">
                        <label for="inputEmail3" class="col-sm-3 col-form-label">Starting Year</label>
                        <div class="col-sm-3">
                            <select class="form-control" id="selStartingYear">
                            </select>
                        </div>
                        <label for="inputEmail3" class="col-sm-2 col-form-label">Status</label>
                        <div class="col-sm-2">
                            <select class="form-control" id="selActiveStatus">
                                <option value="0">Active</option>
                                <option value="1">DeActive</option>
                            </select>
                        </div>
                    </div>
                    

                    <div class="form-group row">
                        <div class="col-sm-12">
                            <span id="spInfo">

                            </span>
                        </div>
                    </div>


                </form>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="main-card mb-3 card">
            <div class="card-body">

                <input type="button" data-tab="12" data-custid="0" value="Save" class="btn btn-block btn-info" id="btnSaveCust" />

                <input type="button" value="Add New" class="btn btn-block btn-danger" id="btnAddNewCust" />





            </div>
        </div>

    </div>
</div>

<div class="row" id="showDiv">
    <div class="col-md-12">
        <div class="main-card mb-3 card">
            <div class="card-body">
                <table style="width: 100%;" id="dataTable" class="table table-hover table-striped table-bordered">
                    <thead>
                        <tr>



                            <th>ID</th>
                            <th>Cust No</th>
                            <th>Sub Cat</th>
                            <th>Name</th>
                            <th>Shop</th>
                            <th>Op Balance</th>
                            <th>District</th>

                            <th>MobileNo</th>
                            <th>Address1</th>

                            <th></th>
                            <th></th>
                        </tr>
                    </thead>

                </table>
            </div>
        </div>
    </div>
</div>




<div class="app-drawer-overlay d-none animated fadeIn"></div>



<div id="modalCategory" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLongTitle">Add Category</h5>
                <button type="button" class="close reset" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="signupForm" class="col-md-12 mx-auto">
                    <input name="partyCode" id="partyCode" type="hidden" class="form-control">
                    <div class="form-row">
                        <div class="col-md-12">
                            <div class="position-relative form-group">
                                <label for="customerName">Category Name</label>
                                <input name="CategoryName" id="txtCatNameEdit" placeholder="Category Name" type="text" class="form-control">
                                <em id="concernNameBengali-error" class="error invalid-feedback">Please enter name</em>
                            </div>
                        </div>

                    </div>
                    <div class="form-row">
                        <div class="col-md-6">

                            <span id="spInfo2">

                            </span>

                        </div>
                        <div class="col-md-6">
                            <input data-catId="0" type="button" id="btnSaveCat" class="btn btn-success" value="Save" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="col-md-12">
                            <table style="width: 100%;" id="tblCat" class="table table-hover table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Name</th>
                                        <th></th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>





                </form>
            </div>
            <div class="modal-footer">
                <button type="button" id="modalCloseCat" class="btn btn-outline-secondary reset" data-dismiss="modal">Close</button>

            </div>
        </div>
    </div>
</div>



<div id="modalDistrict" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLongTitle">Add District</h5>
                <button type="button" class="close reset" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="signupForm" class="col-md-12 mx-auto">
                    <input name="partyCode" id="partyCode" type="hidden" class="form-control">
                    <div class="form-row">
                        <div class="col-md-12">
                            <div class="position-relative form-group">
                                <label for="customerName">District Name</label>
                                <input name="Dsitrict Name" id="txtDistrictNameEdit" type="text" class="form-control">
                                <em id="concernNameBengali-error" class="error invalid-feedback">Please enter name</em>
                            </div>
                        </div>

                    </div>
                    <div class="form-row">
                        <div class="col-md-6">

                            <span id="spInfo4">

                            </span>

                        </div>
                        <div class="col-md-6">
                            <input type="button" data-districtid="0" id="btnSaveDistrict" class="btn btn-success" value="Save" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="col-md-12">
                            <table style="width: 100%;" id="tblDistrict" class="table table-hover table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Name</th>
                                        <th></th>
                                        <th></th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>





                </form>
            </div>
            <div class="modal-footer">
                <button type="button" id="modalCloseCat" class="btn btn-outline-secondary reset" data-dismiss="modal">Close</button>

            </div>
        </div>
    </div>
</div>



<div id="modalSubCategory" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLongTitle">Add Sub Category</h5>
                <button type="button" class="close reset" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="signupForm" class="col-md-12 mx-auto">
                    <input name="partyCode" id="partyCode" type="hidden" class="form-control">
                    <div class="form-row">
                        <div class="col-md-6">
                            <div class="position-relative form-group">
                                <label for="customerName">Category Name</label>
                                <input name="CategoryName" id="txtCatNameEditSub" placeholder="Category Name" type="text" class="form-control" list="dltxtCategory">
                                <em id="concernNameBengali-error" class="error invalid-feedback">Please enter name</em>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="position-relative form-group">
                                <label for="customerName">Sub Category Name</label>
                                <input name="CategoryName" id="txtSubCatNameEditSub" placeholder="Sub Category Name" type="text" class="form-control">
                                <em id="concernNameBengali-error" class="error invalid-feedback">Please enter name</em>
                            </div>
                        </div>

                    </div>


                    <div class="form-row">
                        <div class="col-md-6">
                            <span id="spInfo3">

                            </span>
                        </div>
                        <div class="col-md-6">

                            <input data-subcatId="0" type="button" id="btnSaveSubCat" class="btn btn-success" value="Save" />
                        </div>
                    </div>

                    <div class="form-row">

                        <div class="col-md-12">
                            <table style="width: 100%;" id="tblSubCat" class="table table-hover table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Category</th>
                                        <th>Sub Category</th>
                                        <th></th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>





                </form>
            </div>
            <div class="modal-footer">
                <button type="button" id="modalCloseSubCat" class="btn btn-outline-secondary reset" data-dismiss="modal">Close</button>

            </div>
        </div>
    </div>
</div>


<script type="text/javascript">

    var CUST_LIST = [];
    var CUST_CAT = [];
    var SUB_CUST_CAT = [];
    var tableCust;
    $(document).ready(function () {

        // alert('ghgh');

        LoadDefaultData();


        tableCust = $('#dataTable').DataTable({
            data: [],
            "columnDefs": [

                {
                    "searchable": true,
                    "orderable": false,
                    "targets": 0
                }
            ],
            "language":
            {
                "processing": '<div class="font-icon-wrapper float-left mr-3 mb-3" style="margin-left: 9%;">' +
                    '<div class="loader-wrapper d-flex justify-content-center align-items-center">' +
                    '<div class="loader">' +
                    '<div class="line-scale-pulse-out-rapid">' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '</div>' +
                    '</div>' +
                    '</div>' +
                    '<p>Loading</p></div>'
            },
            //"responsive": true,
            //"processing": true,
            //"serverSide": true,
            "lengthMenu": [
                [10, 15, 25, 50, 100, -1],
                [10, 15, 25, 50, 100, "All"]
            ],

            "order": [1, "asc"],
            "start": 0,
            "length": 10,
            "bFilter": true,

            "columns": [
                { "data": "customerID" },
                { "data": "customerNo" },
                { "data": "customerSubCategory.customerSubCategoryName" },
                { "data": "name" },
                { "data": "shopName" },
                { "data": "openingBalance" },
                { "data": "district.name" },
                { "data": "mobileNo" },
                { "data": "address1" },

                {
                    "data": null,
                    "mRender": function (data, type, full) {
                        return '<button class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-info" onclick="editCustomer(\'' + data.customerID + '\')">Edit</button>';
                    }
                },
                {
                    "data": null,
                    "mRender": function (data, type, full) {
                        return '<button class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-danger" onclick="deleteCustomer(\'' + data.customerID + '\')">Delete</button>';
                    }
                }
            ]
        });

        bindStartingYear();
        function bindStartingYear() {

            var date = new Date();
            var _currentYear =  date.getFullYear();

            $("#selStartingYear").append("<option value='" + _currentYear + "'>" + _currentYear+"</option>")
            $("#selStartingYear").append("<option value='" + (_currentYear - 1) + "'>" + (_currentYear - 1) + "</option>")
            $("#selStartingYear").append("<option value='" + (_currentYear - 2) + "'>" + (_currentYear - 2) + "</option>")

        }




        $("input").on('keypress', function (event) {

            // alert('ok');
            var _currentTab = $(this).attr("data-tab");
            var _id = $(this).attr("id");

            var keycode = (event.keyCode ? event.keyCode : event.which);
            if (keycode == '13') {
                if (_currentTab != undefined) {
                    if (_id !== 'btnSaveCust') {
                        var _nextTab = parseInt(_currentTab) + 1;
                        $('input[data-tab="' + _nextTab + '"]').focus();
                    }
                }
            }


        });




        function LoadDefaultData() {
            ClearControl();
            $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                url: WEB_URL + "Customer/CustomerEntryViewModel",

                // data: JSON.stringify(receiveMain),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();
                    $("#spInfo").html('');
                    console.log(data);
                    //RECEIVE = data;
                    //BindProduct(data);
                    //$("#spInfo").html('');
                    CUST_CAT = data.customerCategorys;
                    CUST_LIST = data.customers;
                    SUB_CUST_CAT = data.customerSubCategorys;
                    LoadCustCategoryName(data.customerCategorys);
                    BinCategoryTable(data.customerCategorys);
                    BindDistrictName(data.districtS);
                    BinSubCategoryTable(data.customerSubCategorys);
                    tableCust.rows.add(data.customers).draw();

                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });
        }
        $("#btnEditCat").click(function () {
            $("#spInfo2").html('');
            ClearControl();
        });
        $("#txtCategory").bind('input', function () {
            // ClearAfterBuyerChange();
            $("#dltxtSubCategory option").remove();
            $("#txtSubCategory").val('');
            // var _thisVal=
            var _val = $(this).val();

            var _catID = GetDataID(_val, "#dltxtCategory");

            if (_catID != undefined) {
                var _SubCatList = SUB_CUST_CAT.filter(function (_obj) {
                    return _obj.customerCategoryID == _catID;
                });

                LoadSubCustName(_SubCatList);
            }

        });


        $("#btnSaveCust").on('click', function () {

            $("input").each(function () {
                $(this).removeClass("input-validation-error");
            });
            $("#spInfo").html('');


            var _custId = $("#btnSaveCust").attr('data-custid');


            var _catName = $("#txtCategory").val();

            var _subcatName = $("#txtSubCategory").val();

            var _shopName = $("#txtShopName").val();

            var _custName = $("#txtCustName").val();

            var _distName = $("#txtDistrict").val();

            var _address = $("#txtAddress").val();

            var _mobile1 = $("#txtMobile1").val();

            var _mobile2 = $("#txtMobile2").val();

            var _OpBal = $("#txtOpBalance").val();

            var _opComm = $("#txtOpComm").val();
            var _opPcs = $("#txtOpPcs").val();

            let _startingYear = $("#selStartingYear").val();

            let _status = $("#selActiveStatus").val();


            var _catID = GetDataID(_catName, "#dltxtCategory");

            var _subCatID = GetDataID(_subcatName, "#dltxtSubCategory");

            var _distID = GetDataID(_distName, "#dltxtDistrict");


            if (_distName == '') {
                $("#txtDistrict").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid District !</strong>');
                return;
            }
            if (_distID == '' || _distID == null || _distID == undefined) {
                $("#txtDistrict").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid District !</strong>');
                return;
            }



            if (_catName == '') {
                $("#txtCategory").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Category !</strong>');
                return;
            }
            if (_catID == '' || _catID == null || _catID == undefined) {
                $("#txtCategory").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Category !</strong>');
                return;
            }
            if (_subcatName == '') {
                $("#txtSubCategory").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Sub Category !</strong>');
                return;
            }


            if (_subCatID == '' || _subCatID == null || _subCatID == undefined) {
                $("#txtSubCategory").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Sub Category !</strong>');
                return;
            }

            if (_shopName == '') {
                $("#txtShopName").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Shop Name !</strong>');
                return;
            }

            if (_custName == '') {
                $("#txtCustName").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Customer Name !</strong>');
                return;
            }
            if (_address == '') {
                $("#txtAddress").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Address !</strong>');
                return;
            }

            if (_mobile1 == '') {
                $("#txtMobile1").addClass("input-validation-error");
                $("#spInfo").html('<strong style="color:red">Invalid Mobilr !</strong>');
                return;
            }


            if (_OpBal == '') {
                _OpBal = '0';
            }
            if (_opComm == '') {
                _opComm = '0';
            }
            if (_opPcs == '') {
                _opPcs = '0';
            }


            $("#spInfo").html('<strong>Please wait ....</strong>');
            var customer = {
                "CustomerID": _custId,
                "CustomerNo": 0,
                "DistrictID": _distID,
                "Name": _custName,
                "ShopName": _shopName,
                "MobileNo": _mobile1,
                "MobileNo2": _mobile2,
                "Address1": _address,
                "Address2": _address,


                "OpeningBalance": _OpBal,
                "OpeningCommission": _opComm,
                "OpeningQty": _opPcs,
                "CurrentBalance": _OpBal,

                "CustomerSubCategoryID": _subCatID,
                "StartingYear": _startingYear == null || undefined ? 0 : _startingYear,
                "IsBlocked": _status

            }

            console.log(customer);

            $.ajax({
                type: "POST",
                url: WEB_URL + "Customer/AddCustomer",

                data: JSON.stringify(customer),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();

                    console.log(data);

                    if (parseInt(data.resultID) == -1) {
                        $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');

                    }
                    else {
                        ClearControl();
                        $("#spInfo").html('<strong style="color:green">' + data.resultMessage + '</strong>');
                        CUST_LIST = data.obj;
                        // tableCust.fnClearTable();
                        tableCust.clear().draw();
                        tableCust.rows.add(data.obj).draw();

                    }




                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });



        });



        $("#btnSaveCat").on('click', function () {

            $("input").each(function () {
                $(this).removeClass("input-validation-error");
            });

            var _id = $("#btnSaveCat").attr('data-catId');

            $("#spInfo2").html('');

            var _catName = $("#txtCatNameEdit").val();

            if (_catName == '') {
                $("#txtCatNameEdit").addClass("input-validation-error");
                $("#spInfo2").html('<strong style="color:red">Invalid Product !</strong>');
                return;
            }
            $("#spInfo2").html('<strong>Please wait ....</strong>');
            var customerCategory = {
                "CustomerCategoryID": _id,
                "CustomerCategoryName": _catName
            }
            $.ajax({
                type: "POST",
                url: WEB_URL + "CustomerCategory/InsertNewCustomerCategory",

                data: JSON.stringify(customerCategory),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();

                    console.log(data);


                    if (parseInt(data.resultID) == -1) {
                        $("#spInfo2").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                    }
                    else {
                        ClearControl();
                        $("#spInfo2").html('<strong style="color:green">' + data.resultMessage + '</strong>');
                        CUST_CAT = data.obj;
                        LoadCustCategoryName(data.obj)
