                                    data-toggle="modal" data-target="#modalInvoice" id="btnViewModel">
                                Modal View
                            </button>
                        </div>

                        <div class="col-sm-1">

                        </div>

                        <div class="col-sm-2"><input type="button" value="Add New" class="btn btn-danger btn-block" id="btnAddNewCust" /></div>
                        <div class="col-sm-1">

                        </div>

                        <div class="col-sm-2">
                            <input data-tab="24" type="button" data-salesHeadID="0" data-salesDetailsID="0" value="Save" class="btn  btn-info btn-block" id="btnSaveCust" />


                        </div>








                    </div>

                    <div class="form-row">
                        <label for="inputEmail3" class="col-sm-1 col-form-label">তারিখ:</label>
                        <div class="col-sm-2">
                            <input type="text" data-tab="1" autocomplete="off" class="form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDate2" />
                            @*<input type="text" disabled class="mb-1 form-control-sm form-control" data-date-format="dd-mm-yyyy" id="txtDate">*@
                        </div>
                        <div class="col-sm-2">



                        </div>




                    </div>


                    <div class="form-row">

                        <div class="col-md-2">

                            <label for="exampleCity">পণ্যের নাম</label>
                            <input autocomplete="off" data-tab="5" id="txtProName" type="text" class="form-control-sm form-control" list="dltxtProName" />
                            <datalist id="dltxtProName"></datalist>

                        </div>
                        <div class="col-md-2">

                            <label for="exampleCity">আর্টিকেল</label>
                            <input data-tab="6" autocomplete="off" id="txtArcticle" type="text" class="form-control-sm form-control" list="dltxtArcticle" />
                            <datalist id="dltxtArcticle"></datalist>
                        </div>

                        <div class="col-md-2">

                            <label for="exampleCity">সাইজ</label>
                            <input autocomplete="off" id="txtSize" disabled type="text" class="form-control-sm form-control" list="dltxtSize" />
                            <datalist id="dltxtSize"></datalist>
                        </div>

                        <div class="col-md-2">
                            <label for="exampleCity">জোড়া</label>
                            <input min="0" data-tab="7" autocomplete="off" id="txtPair" type="text" class="form-control-sm form-control" />

                        </div>
                        <div class="col-md-1">

                            <label for="exampleCity"></label>
                            <br />
                            <input data-tab="8" type="button" data-salesHeadID="0" data-salesDetailsID="0" data-companyProductID="0" data-slno="0" value="Add" class="btn btn-success" id="btnAdd" />



                        </div>

                        <div class="col-md-1">
                            <label for="exampleCity">মোট জোড়া</label>
                            <input type="number" disabled autocomplete="off" id="txtTotalpair" />
                        </div>
                    </div>



                    <div class="form-row">
                        <div class="col-md-6">

                            <label for="exampleCity">নোট</label>
                            <input autocomplete="off" id="txtNote1" type="text" class="form-control-sm form-control" />


                        </div>

                    </div>



                    <div class="form-group row">
                        <div class="col-sm-12">
                            <span id="spInfo">

                            </span>
                        </div>
                    </div>
                </form>
            </div>

        </div>

    </div>


</div>


<div class="row flex-sm-row">
    <div class="col-md-12" style="padding-top:0em; padding-bottom:0em;">

        <div class="main-card mb-3 card" style=" margin-bottom: 0em !important;">
            <div class="card-body">


                <table id="tblProdItem" class="table table-sm table-bordered" style="margin-bottom:0 !important ">
                    <thead>
                        <tr>
                            <th style="display:none">CommProductID</th>
