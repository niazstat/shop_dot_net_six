
@{
    ViewData["Title"] = "BankEntry";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


@section HeadingText {
    <div class="page-title-heading">
        ..::   ব্যাংক এন্ট্রি    ::..
        <div class="page-title-subheading">

        </div>
    </div>

}


<style type="text/css" media="print">
    @@page {
        size: auto; /* auto is the initial value */
        margin: 2mm 4mm 0mm 0mm; /* this affects the margin in the printer settings */
    }

    thead {
        display: table-header-group;
    }

    tfoot {
        display: table-footer-group;
    }
</style>
<div class="row flex-sm-row">
    <div class="col-md-3">
        <label for="inputEmail3" class="col-form-label">নাম :</label>

    </div>

    <div class="col-md-6">
        <input type="text" class="form-control-sm form-control" id="txtName">
    </div>
</div>
<div class="row flex-sm-row">
    <div class="col-md-3">
        <label for="inputEmail3" class="col-form-label">শর্ট নাম :</label>

    </div>

    <div class="col-md-6">
        <input type="text" class="form-control-sm form-control" id="txtShortName">
    </div>
</div>



<div class="form-group row">
    <div class="col-sm-12">
        <span id="spInfo">

        </span>
    </div>
</div>

<div class="row flex-sm-row">
    <div class="col-md-3"></div>
    <div class="col-md-3">
        <input type="button" data-bankID="0" value="Save" class="btn  btn-info" id="btnSaveCust" />

    </div>

    <div class="col-md-3">

        <input type="button" value="Add New" class="btn  btn-danger" id="btnAddNewCust" />
    </div>
</div>



<div class="row" id="showDiv">
    <div class="col-md-12">
        <div class="main-card mb-3 card">
            <div class="card-body">
                <table style="width: 100%;" id="dataTable" class="table table-hover table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>আইডি</th>
                            <th>নাম</th>
                            <th>শর্ট নাম</th>


                            <th></th>
                            <th></th>
                        </tr>
                    </thead>

                </table>
            </div>
        </div>
    </div>
</div>




<script type="text/javascript">


    var tableCust;
    $(document).ready(function () {









        tableCust = $('#dataTable').DataTable({
            data: [],
            "columnDefs": [

                {
                    "searchable": true,
                    "orderable": false,
                    "targets": 0
                }
            ],
            "language":
            {
                "processing": '<div class="font-icon-wrapper float-left mr-3 mb-3" style="margin-left: 9%;">' +
                    '<div class="loader-wrapper d-flex justify-content-center align-items-center">' +
                    '<div class="loader">' +
                    '<div class="line-scale-pulse-out-rapid">' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '<div></div>' +
                    '</div>' +
                    '</div>' +
                    '</div>' +
                    '<p>Loading</p></div>'
            },
            //"responsive": true,
            "processing": true,
            //"serverSide": true,
            "lengthMenu": [
                [10, 15, 25, 50, 100, -1],
                [10, 15, 25, 50, 100, "All"]
            ],

            "order": [0, "desc"],
            "start": 0,
            "length": 10,
            "bFilter": true,

            "columns": [
                { "data": "bankID" },
                { "data": "name" },
                { "data": "shortName" },


                {
                    "data": null,
                    "mRender": function (data, type, full) {
                        return '<button class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-info" onclick="editCustomer(\'' + data.bankID + '\')">Edit</button>';
                    }
                },
                {
                    "data": null,
                    "mRender": function (data, type, full) {
                        return '<button class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-danger" onclick="deleteCustomer(\'' + data.bankID + '\')">Delete</button>';
                    }
                }
            ]
        });


        LoadDefaultData();



        function LoadDefaultData() {
            //ClearControl();
            $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                url: WEB_URL + "ChequeTransaction/GetBaknEntrytViewModel",

                // data: JSON.stringify(receiveMain),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();
                    $("#spInfo").html('');
                    console.log(data);



                    tableCust.rows.add(data.banks).draw();

                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });
        }









        $("#btnSaveCust").click(function () {
            $("#spInfo").html('');

            let _bankID = $(this).attr('data-bankID');

            let _name = $("#txtName").val();
            let _shortname = $("#txtShortName").val();


            if (_name == undefined || _name == null || _name == '') {

                $("#spInfo").html('<strong style="color:red">Invalid Name!</strong>');

                $("#txtName").focus();
                return;
            }





            var bank = {
                "BankID": parseInt(_bankID),
                "Name": _name,
                "ShortName": _shortname

            }

            console.log(bank);
            $("#spInfo").html('<strong style="color:blue">Savng Data Please wait.. !</strong>');

            $.ajax({
                type: "POST",
                url: WEB_URL + "ChequeTransaction/SaveBank",

                data: JSON.stringify(bank),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    console.log(data);
                    if (parseInt(data.resultID) > 0) {
                        $("#txtInvoiceNo").val(data.resultNo);
                        $("#spInfo").html('<strong style="color:blue">' + data.resultMessage + '</strong>');
                        ClearControlAfterSave();
                        tableCust.clear().draw();
                        tableCust.rows.add(data.obj).draw();

                    }
                    else {
                        // HideGateOverlay();
                        $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                    }


                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });




        });



        $("#btnAddNewCust").click(function () {
            ClearControlAfterSave();

        });






    });




    function editCustomer(id) {
        // ClearControl();

        var bank = {
            "bankID": id
        }
        // alert(id);
        $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + "ChequeTransaction/GetBank",

            data: JSON.stringify(bank),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);
                if (parseInt(data.resultID) == -1) {
                    $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                }
                else {
                    $("#spInfo").html(data.resultMessage);
                    $("#btnSaveCust").val('Update');
                    $("#btnSaveCust").attr('data-bankID', data.obj.bankID);
                    $("#txtName").val(data.obj.name);
                    $("#txtShortName").val(data.obj.shortName);
                }

            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });



    }

    function deleteCustomer(id) {

        // ClearControl();

        if (confirm('Are you sure to delete Customer?')) {
            // Save it!
            console.log('Thing was saved to the database.');
        }
        else {
            return;
        }




        var bank = {
            "bankID": id
        }

        //alert(id);
        $("#spInfo").html('<strong style="color:blue"> Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + "ChequeTransaction/DeleteBank",

            data: JSON.stringify(bank),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);



                if (parseInt(data.resultID) == -1) {
                    $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');

                }
                else {
                    //ClearControl();
                    $("#spInfo").html('<strong style="color:green">' + data.resultMessage + '</strong>');


                    //ClearControlAfterSave();
                    tableCust.clear().draw();
                    tableCust.rows.add(data.obj).draw();

                }





                $("#spInfo").html('');

            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });

    }


    function ClearControlAfterSave() {

        $("#txtName").val('');
        $("#txtShortName").val('');
        $("#btnSaveCust").removeAttr('disabled');
        $("#btnSaveCust").val('Save');
        $("#btnSaveCust").attr('data-bankID', '0');

    }


</script>