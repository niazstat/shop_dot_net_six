        function LoadDefaultData() {
            //ClearControl();
            $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                url: WEB_URL + CONTROLLERANME +"/ExpensesEntryViewModel",

               //data: JSON.stringify(receiveMain),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();
                    $("#spInfo").html('');
                    console.log(data);
                    BindEmployees(data.employees);
                    BindExpensesHead(data.expensesHeads);
                    tableCust.rows.add(data.expenses).draw();

                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });
        }



        $("#chkEmployeeExpenses").change(function () {
            if ($(this).is(':checked')) {
                $("#txtExpensesName").attr('disabled', 'disabled');
        
                $("#selEmp").removeAttr('disabled');


                $("#txtExpensesName").val('');
          
            }

            else {
                $("#txtExpensesName").removeAttr('disabled');

                $("#selEmp").attr('disabled', 'disabled');
                $("#selEmp").val('');
            }
        });


        function LoadCurrentMonthExpensesData() {
            //ClearControl();
            var expense = {
                'TranDate': $("#txtDateEntry").val()
            }


            $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                url: WEB_URL + CONTROLLERANME + "/LoadCurrentMonthExpensesData",

                data: JSON.stringify(expense),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();
                    $("#spInfo").html('');
                    console.log(data);
                 
           
                   
                    tableCust.clear().draw();
                    tableCust.rows.add(data.obj).draw();

                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });
        }






        function BindExpensesHead(_obj) {
            $("#dlExpensesHead option").remove();
            $("#tblExpensesHead tr:gt(0)").remove();
            $.each(_obj, function (i, prodData) {

                $("#dlExpensesHead").append(' <option data-id="' + prodData.expensesHeadID + '" data-custID="' + prodData.expensesHeadID + '" value="' + prodData.name + '" />');
                $("#tblExpensesHead").append('<tr> <td>' + prodData.expensesHeadID + '</td> <td>' + prodData.name + '</td> <td>' + '  <button data-for="edit" data-expensesheadid=' + prodData.expensesHeadID + ' class= "mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-info"  > <i class="pe-7s-pen btn-icon-wrapper"> </i>Edit</button > <button data-for="delete" data-expensesheadid=' + prodData.expensesHeadID + ' class="mb-2 mr-2 btn-icon btn-shadow btn-dashed btn btn-outline-danger" ><i class="pe-7s-trash btn-icon-wrapper"> </i>Delete</button>' + '</td> </tr> ');

            });

        }

        function BindEmployees(_obj) {
            console.log(_obj);
            $("#selEmp option").remove();
            $("#selEmp").append(' <option></option>');

            $.each(_obj, function (i, prodData) {

                $("#selEmp").append(' <option data-salary="' + prodData.salary + '" data-id="' + prodData.employeeID + '" data-custID="' + prodData.employeeID + '" value="' + prodData.employeeID + '" > ' + prodData.name + '</option>');

            });

        }


        $("#btnAddNewCust").on('click', function () {

            ClearControlAfterSave();
        });

        $("#btnSavedHead").on('click', function () {

            $("input").each(function () {
                $(this).removeClass("input-validation-error");
            });

            var _id = $(this).attr('data-expensesheadid');
            $("#spInfo2").html('');


            var _headName = $("#txtExpensesNameEdit").val();

            if (_headName == '') {
                $("#txtExpensesNameEdit").addClass("input-validation-error");
                $("#spInfo2").html('<strong style="color:red">Invalid Name !</strong>');
                return;
            }
            $("#spInfo2").html('<strong>Please wait ....</strong>');
            var designation = {
                "ExpensesHeadID": _id,
                "Name": _headName
            }
            $.ajax({
                type: "POST",
                url: WEB_URL + CONTROLLERANME + "/SaveExpensesHead",

                data: JSON.stringify(designation),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();

                    console.log(data);


                    if (parseInt(data.resultID) == -1) {
                        $("#spInfo2").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                    }
                    else {
                        ClearExpenseHeadControl();
                        $("#spInfo2").html('<strong style="color:green">' + data.resultMessage + '</strong>');
                        BindExpensesHead(data.obj);
                    }



                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });

        });
    
        function ClearExpenseHeadControl() {
            $("#btnSavedHead").attr('data-expensesheadid', '0');
            $("#btnSavedHead").val('Save');
            $("#txtExpensesNameEdit").val('');
        }
  

     

        $("#btnSaveCust").on('click', function () {

            let _expenseID = $(this).attr("data-expenseID");
            let _tranDate = $("#txtDateEntry").val();
            let _type = $("#selRecvPay").val();
     

            let _headName = $("#txtExpensesName").val();
            let _isEmployeeExpenses = $("#chkEmployeeExpenses").is(':checked');
              
            var _empId = $("#selEmp").val();


            let _headID = GetDataID(_headName, "#dlExpensesHead");

            let _note = $("#txtNote").val();

            let _amount = ConvertBanglaToEnglish($("#txtAmount").val())
            if (_type == '' || _type == '-') {
                $("#spInfo").html('<strong style="color:red">Invalid Type Receive or Payment</strong>');
                $("#selRecvPay").focus()
                return;
            }

      
            if (_isEmployeeExpenses!=true &&(  _headID == undefined || _headID == null)) {
                $("#spInfo").html('<strong style="color:red">Invalid Account !</strong>');
                $("#txtExpensesName").focus()
                return;
            }
            if (_isEmployeeExpenses == true && (_empId == undefined || _empId == '' || _empId==null) ) {
                $("#spInfo").html('<strong style="color:red">Invalid Employee !</strong>');
                $("#selEmp").focus()
                return;
            }
            if (_amount == '' || parseFloat(_amount)  == 0) {
                $("#spInfo").html('<strong style="color:red">Invalid Amount !</strong>');
                $("#txtAmount").focus()
                return;
            }
         
            if (_isEmployeeExpenses) {
                _headID='0'
            }
            else {
                _empId='0'
            }



            let expense = {
                "ExpenseID": parseInt(_expenseID),
                "IsEmployeeExpenses": _isEmployeeExpenses,
                "Employee": {
                    "EmployeeID": parseInt(_empId)
                },
                "TranDate": _tranDate,
                "Type": _type,
                "ExpensesHead": { "ExpensesHeadID": parseInt(_headID) },     
                "Amount":parseFloat( _amount),
                "Note": _note,
           
            }

            console.log(expense);

            $("#spInfo").html('<strong style="color:blue">Saving Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                data: JSON.stringify(expense),
                url: WEB_URL + CONTROLLERANME + "/SaveExpenses",
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();

                    console.log(data);
                    if (parseInt(data.resultID) > 0) {
                        $("#txtInvoiceNo").val(data.resultNo);
                        $("#spInfo").html('<strong style="color:blue">' + data.resultMessage + '</strong>');
                        ClearControlAfterSave();
                        tableCust.clear().draw();
                        tableCust.rows.add(data.obj).draw();
                       // $("#btnSaveCust").attr('disabled', 'disabled');

                       // BindData(data.obj, 'disabled');
                    }
                    else {
                        // HideGateOverlay();
                        $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                    }
                   // BindSuppliers(data);


                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });


        });


        $("#tblExpensesHead").on('click', 'tr td button', function (e) {

            ClearExpenseHeadControl();

            $("#spInfo2").html('');
            //alert('working in Progress');
            //var thisTxtBox = $(this);
            e.preventDefault();

            var _for = $(this).attr("data-for");
            var _id = $(this).attr("data-expensesheadid");
            var designation = {
                "ExpensesHeadID": _id
            }



            if (_for == 'edit') {
                LoadExpensesHeadForEdit(designation);
            }

            if (_for == 'delete') {


                if (confirm('Are you sure to delete Category?')) {
                    // Save it!
                    DeleteExpensesHead(designation)
                }
                else {
                    return;
                }


            }
        });




        function LoadExpensesHeadForEdit(_obj) {
            $("#spInfo2").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
            $.ajax({
                type: "POST",
                url: WEB_URL + CONTROLLERANME +"/GetExpensesHead",

                data: JSON.stringify(_obj),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    console.log(data);
                 
                    
                    $("#spInfo2").html('');

                    $("#btnSavedHead").attr('data-expensesheadid', data.expensesHeadID);
                    $("#btnSavedHead").val('Update');
                    $("#txtExpensesNameEdit").val(data.name);

                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });
        }



        function DeleteExpensesHead(_designation) {

            $("#spInfo2").html('<strong>Please wait ....</strong>');

            $.ajax({
                type: "POST",
                url: WEB_URL + CONTROLLERANME +"/DeleteExpensesHead",

                data: JSON.stringify(_designation),
                dataType: "JSON",
                contentType: "application/json;charset=utf-8",
                success: function (data) {
                    // HideGateOverlay();

                    console.log(data);


                    if (parseInt(data.resultID) == -1) {
                        $("#spInfo2").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                    }
                    else {
                        $("#txtCatNameEdit").val('');
                        $("#spInfo2").html('<strong style="color:green">' + data.resultMessage + '</strong>');

                        BindExpensesHead(data.obj);
                    }


                },
                error: function (a, b, c) {
                    //  HideGateOverlay();
                    alert(a, c);
                }
            });

        }

    });



    function editCustomer(id) {
        // ClearControl();
        ClearControlAfterSave();
        var expense = {
            "ExpenseID": id
        }
        // alert(id);
        $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + CONTROLLERANME +"/GetExpenses",

            data: JSON.stringify(expense),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);
                if (parseInt(data.resultID) == -1) {
                    $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                }
                else {

                    let _obj = data.obj;
                    $("#spInfo").html(data.resultMessage);
                    $("#btnSaveCust").val('Update');
                    $("#btnSaveCust").attr('data-expenseID', _obj.expenseID);

                    $("#txtInvoiceNo").val(_obj.generatedAutoSLNo);

                    $("#txtDate").val(_obj.tranDateFormatted);
                    $("#selRecvPay").val(_obj.type);
                    $("#txtExpensesName").val(_obj.expensesHead.name);
               
               

                   // $("#txtCustomer").val(data.obj.supplier.name);
                    $("#txtAmount").val(_obj.amount);
                    $("#txtNote").val(_obj.note);
                    $("#txtDateEntry").val(_obj.tranDateFormated);

                    if (_obj.isEmployeeExpenses) {

                        $("#selEmp").removeAttr('disabled');
                        $("#txtExpensesName").attr('disabled', 'disabled');
                        $("#chkEmployeeExpenses").prop("checked", true);
                    }
                    else {
                        $("#selEmp").attr('disabled', 'disabled');
                        $("#txtExpensesName").removeAttr('disabled');
                        $("#chkEmployeeExpenses").prop("checked", false);
                    }


                    if (_obj.employee != null) {

                        $("#selEmp").val(_obj.employee.employeeID);

                    }
                    else {
                        $("#selEmp").val('');
                    }
          

                }



            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });



    }


    function deleteCustomer(id) {

        ClearControlAfterSave();
        var expense = {
            "ExpenseID": id
        }

        if (confirm('Are you sure to delete Customer?')) {
            // Save it!
            console.log('Thing was saved to the database.');
        }
        else {
            return;
        }

        $("#spInfo").html('<strong style="color:blue"> Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + CONTROLLERANME +"/DeleteExpenses",

            data: JSON.stringify(expense),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);



                if (parseInt(data.resultID) == -1) {
                    $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');

                }
                else {
                    ClearControlAfterSave();
                    $("#spInfo").html('<strong style="color:green">' + data.resultMessage + '</strong>');

                    tableCust.clear().draw();
                    tableCust.rows.add(data.obj).draw();
                }
                $("#spInfo").html('');

            },
            error: function (a, b, c) {
                //  HideGateOverlay();
                alert(a, c);
            }
        });

    }








    function ClearControlAfterSave() {
        $("#btnSaveCust").attr("data-expenseID", "0");
        $("#txtDate").val(today);
        $("#txtExpensesName").val('');
        $("#txtNote").val('');
        $("#selRecvPay").val('');
        $("#txtAmount").val('0');
       
        $("#selEmp").val('');
        $("#chkEmployeeExpenses").prop("checked", false);
        $("#txtExpensesName").removeAttr('disabled');
        $("#selEmp").attr('disabled', 'disabled');
        $("#btnSaveCust").val("Save");

    }


    function GetDataID(value, dataList) {
        var z = $(dataList);
        var val = $(z).find('option[value="' + value + '"]');
        var endval = val.attr('data-id');
        return endval;
    }
</script>