                [10, 15, 25, 50, 100, "All"]
            ],

            "order": [0, "desc"],
            "start": 0,
            "length": 10,
            "bFilter": true,

            "columns": [
                { "data": "autoSLNo" },
                { "data": "generatedAutoSLNo2" },
                { "data": "tranDateFormated" },
                { "data": "type" },
             
            
