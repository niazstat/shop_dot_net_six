
@model List<SP_Employee_Salary_and_Expenses>

@{
    ViewData["Title"] = "EmployeeSalaryWithdrawView";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section HeadingText {
    <div class="page-title-heading text-dark text-center">
        .:: Employe Salary Withdraw Report ::.
    </div>
}
<style type="text/css" media="print">
    @@page {
        size: auto; /* auto is the initial value */
        margin: 2mm 4mm 2mm 2mm; /* this affects the margin in the printer settings */
    }

    thead {
        display: table-header-group;
    }

    tfoot {
        display: table-footer-group;
    }
</style>

<div class="row">
    <div class="col-sm-1">
        <input type="button" class="btn btn-outline-primary" value="Print/PDF"
               id="btPrint" onclick="createPDF()" />
    </div>
    <div class="col-sm-1">

    </div>
</div>

<div class="form-group row">
    <div class="col-sm-12">
        <span id="spInfo">

        </span>
    </div>
</div>

<div class="row" id="tab">
    <div class="col-sm-12">
        <style>
            .CSSTableGenerator {
                margin: 0px;
                padding: 0px;
                width: 100%;
                border: thin solid #000000;
            }

                .CSSTableGenerator table {
                    border-collapse: collapse;
                    border-spacing: 0;
                    width: 100%;
                    height: 100%;
                    margin: 0px;
                    padding: 0px;
                }


                .CSSTableGenerator tr:nth-child(odd) {
                }

                .CSSTableGenerator tr:nth-child(even) {
                }

                .CSSTableGenerator td {
                    vertical-align: middle;
                    border: thin solid #000000;
                    border-width: 0px thin thin 0px;
                    text-align: left;
                    padding: 2px;
                    font-size: .8em;
                    font-family: Trebuchet MS,Arial,Helvetica,sans-serif;
                    font-weight: normal;
                }

                .CSSTableGenerator tr:last-child td {
                    border-width: 0px thin 0px 0px;
                }

                .CSSTableGenerator tr td:last-child {
                    border-width: 0px 0px thin 0px;
                }

                .CSSTableGenerator tr:last-child td:last-child {
                    border-width: 0px 0px 0px 0px;
                }

                .CSSTableGenerator tr:first-child td {
                    border: 0px solid #000000;
                    text-align: center;
                    border-width: 0px 0px thin thin;
                    font-size: 0.8em;
                    font-family: Arial;
                    font-family: Trebuchet MS,Arial,Helvetica,sans-serif;
                    color: black;
                }

                    .CSSTableGenerator tr:first-child td:first-child {
                        border-width: 0px 0px thin 0px;
                    }

                    .CSSTableGenerator tr:first-child td:last-child {
                        border-width: 0px 0px thin thin;
                    }

            .CSSTableGenerator2 {
                margin: 0px;
                padding: 0px;
                width: 100%;
            }

                .CSSTableGenerator2 tr:nth-child(odd) {
                    text-align: center;
                }

                .CSSTableGenerator2 tr:nth-child(even) {
                    text-align: center;
                }


            .tdClass {
                color: #666;
                font-family: Trebuchet MS,Arial,Helvetica,sans-serif;
                font-weight: bold;
                text-align: left;
            }
        </style>


        <div class="col-sm-12" style="text-align:center">

            <p>
                <strong>   @TempData["CompanyName"].ToString();</strong><br />
                @TempData["CompanyAddress"].ToString();<br>
                <span id="spTitle">   @TempData["Title"].ToString()</span><br />

            </p>
            <p class="col-sm-12" style="text-align:left">
                <span id="spFilter">  @TempData["Filter"].ToString()</span>
            </p>
        </div>
    </div>


    <table id="tblOrder" class="CSSTableGenerator" style="margin:auto 5px auto 5px;">
        <tr><td>SL</td><td>Inv</td><td>Date</td><td style="width:20%">Employee Name</td><td style="width:15%">Head Name</td><td style="text-align:right;">Withdraw <br> Amount </td><td style="width:20%">Note</td><td style="width:20%">Signature</td></tr>

        @{
            int _sl = 1;

            decimal totlNetPayAmount = 0;

            foreach (var item in Model)
            {
                <tr><td>@_sl.ToString()</td><td>@item.InvNo</td><td>@item.dDateFormated</td><td>@item.EmployeeName</td><td>@item.HeadName</td><td style="text-align:right;">@item.NetPayAmount </td><td style="width:20%">@item.Remarks</td><td style="width:20%"></td></tr>

                _sl += 1;
                totlNetPayAmount += item.NetPayAmount;
            }
            <tr><td colspan="5"></td><td style="text-align:right;">@totlNetPayAmount.ToString()</td><td ></td><td ></td></tr>

        }


    </table>


</div>

