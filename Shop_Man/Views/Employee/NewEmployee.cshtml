    function editCustomer(id) {
        // ClearControl();

        var employee = {
            "employeeID": id
        }
        // alert(id);
        $("#spInfo").html('<strong style="color:blue">Loading Data Please wait.. !</strong>');
        $.ajax({
            type: "POST",
            url: WEB_URL + "Employee/GetEmployee",

            data: JSON.stringify(employee),
            dataType: "JSON",
            contentType: "application/json;charset=utf-8",
            success: function (data) {
                console.log(data);
                if (parseInt(data.resultID) == -1) {
                    $("#spInfo").html('<strong style="color:red">' + data.resultMessage + '</strong>');
                }
                else {
                 
                        var _obj = data.obj;

                        $("#spInfo").html(data.resultMessage);
                        $("#btnSaveCust").val('Update');
                        $("#btnSaveCust").attr('data-employeeID', _obj.employeeID);




                        $("#txtName").val(_obj.name);

                        $("#txtDesignation").val(_obj.designation.name);


                        $("#txtMotherName").val(_obj.motherName);


                        $("#txtFatherName").val(_obj.fatherName);

                        $("#TxtIDNo").val(_obj.generatedCode);
                        $("#txtSlNo").val(_obj.employeeID);
                        //generatedCode
                        $("#txtMobileNo").val(_obj.mobile1);

                        $("#txtHouseNo").val(_obj.houseNo);

                        $("#txtSalary").val(_obj.salary);

                        $("#txtRoadNo").val(_obj.roadNo);


                        $("#txtJoiningDate").val(_obj.joiningDateFormated);

                        $("#txtCurrentAddress").val(_obj.currentAddress);

                        $("#txtPermanentAddress").val(_obj.permanentAddress);

                        $("#selReligion").val(_obj.religion);


                        $("#txtVillage").val(_obj.village);

                        $("#selBloodGroup").val(_obj.bloodGroup);

                        $("#txtThana").val(_obj.thana);
                        $("#txtNID").val(_obj.nid);

                        $("#txtDistrict").val(_obj.district);

                        $("#txtDateOfBirth").val(_obj.dateOfBirthFormated);

                        $("#txtDivision").val(_obj.division);
                        $("#selMaleFemale").val(_obj.maleFemale);


